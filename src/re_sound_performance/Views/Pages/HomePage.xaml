<Page x:Class="re_sound_performance.Views.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Background="{StaticResource ReSound.Surface.AppBackground}"
      Title="Home">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="44,32,44,40">
        <StackPanel MaxWidth="1100" HorizontalAlignment="Left">

            <!-- Hero -->
            <Border CornerRadius="16"
                    Padding="30,26"
                    Margin="0,0,0,24"
                    BorderThickness="1"
                    BorderBrush="{StaticResource ReSound.Surface.Divider}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF1C1030" Offset="0" />
                        <GradientStop Color="#FF120D24" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#7C3AED" BlurRadius="30" ShadowDepth="0" Opacity="0.25" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Border CornerRadius="8" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,10"
                                Background="{StaticResource ReSound.Accent.Deep}">
                            <TextBlock Text="RE_SOUND PERFORMANCE"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ReSound.Accent.Light}"
                                       TextOptions.TextFormattingMode="Display" />
                        </Border>
                        <TextBlock Style="{StaticResource ReSound.Text.Display}" Text="Windows 11 gaming optimization" Margin="0,0,0,6" />
                        <TextBlock Style="{StaticResource ReSound.Text.Subtitle}" TextWrapping="Wrap" MaxWidth="720"
                                   Text="Tune Windows for low-latency, high-FPS gaming. Every tweak is probed, reversible and documented — no registry files from a stranger, no black magic." />
                    </StackPanel>

                    <Ellipse Grid.Column="1"
                             Width="160"
                             Height="160"
                             Margin="40,0,0,0"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Right">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#807C3AED" Offset="0" />
                                <GradientStop Color="#007C3AED" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>
            </Border>

            <!-- Detection row -->
            <Grid x:Name="DetectionRow" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ReSound.Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ReSound.Text.StatLabel}" Text="HARDWARE" />
                        <TextBlock x:Name="HwPrimary" Style="{StaticResource ReSound.Text.Title}" FontSize="15" Margin="0,6,0,2" Text="Detecting..." />
                        <TextBlock x:Name="HwSecondary" Style="{StaticResource ReSound.Text.Body}" Text="" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ReSound.Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ReSound.Text.StatLabel}" Text="ANTI-CHEAT" />
                        <TextBlock x:Name="AcPrimary" Style="{StaticResource ReSound.Text.Title}" FontSize="15" Margin="0,6,0,2" Text="Scanning..." />
                        <ItemsControl x:Name="AcDetails">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Preset selector -->
            <Border Style="{StaticResource ReSound.Card}" Margin="0,0,0,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource ReSound.Text.Title}" FontSize="16" Text="Presets" />
                        <TextBlock Style="{StaticResource ReSound.Text.Body}" Margin="10,2,0,0" Text="Bundles of recommended tweaks, applied in order with anti-cheat awareness." />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="PresetCardSafe"
                                Grid.Column="0"
                                Style="{StaticResource ReSound.Card}"
                                Cursor="Hand"
                                Tag="Safe"
                                MouseLeftButtonUp="PresetCard_Click">
                            <StackPanel>
                                <TextBlock Text="SAFE" FontWeight="Bold" FontSize="12" Foreground="{StaticResource ReSound.Risk.Safe}" Margin="0,0,0,8" />
                                <TextBlock x:Name="PresetSafeName" Text="Safe" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource ReSound.Text.Primary}" />
                                <TextBlock x:Name="PresetSafeTagline" Style="{StaticResource ReSound.Text.Body}" Margin="0,2,0,10" />
                                <TextBlock x:Name="PresetSafeCount" FontSize="11" Foreground="{StaticResource ReSound.Text.Muted}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="PresetCardBalanced"
                                Grid.Column="2"
                                Style="{StaticResource ReSound.Card}"
                                Cursor="Hand"
                                Tag="Balanced"
                                MouseLeftButtonUp="PresetCard_Click">
                            <StackPanel>
                                <TextBlock Text="BALANCED" FontWeight="Bold" FontSize="12" Foreground="{StaticResource ReSound.Risk.Medium}" Margin="0,0,0,8" />
                                <TextBlock x:Name="PresetBalancedName" Text="Balanced" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource ReSound.Text.Primary}" />
                                <TextBlock x:Name="PresetBalancedTagline" Style="{StaticResource ReSound.Text.Body}" Margin="0,2,0,10" />
                                <TextBlock x:Name="PresetBalancedCount" FontSize="11" Foreground="{StaticResource ReSound.Text.Muted}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="PresetCardCompetitive"
                                Grid.Column="4"
                                Style="{StaticResource ReSound.Card}"
                                Cursor="Hand"
                                Tag="Competitive"
                                MouseLeftButtonUp="PresetCard_Click">
                            <StackPanel>
                                <TextBlock Text="COMPETITIVE" FontWeight="Bold" FontSize="12" Foreground="{StaticResource ReSound.Risk.High}" Margin="0,0,0,8" />
                                <TextBlock x:Name="PresetCompetitiveName" Text="Competitive" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource ReSound.Text.Primary}" />
                                <TextBlock x:Name="PresetCompetitiveTagline" Style="{StaticResource ReSound.Text.Body}" Margin="0,2,0,10" />
                                <TextBlock x:Name="PresetCompetitiveCount" FontSize="11" Foreground="{StaticResource ReSound.Text.Muted}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Preset run status -->
            <Grid x:Name="PresetRunRow" Margin="0,0,0,18" Visibility="Collapsed">
                <Border Style="{StaticResource ReSound.Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PresetRunText" Grid.Column="0" Style="{StaticResource ReSound.Text.Title}" FontSize="15" Text="Applying preset..." />
                            <Button x:Name="PresetCancelButton" Grid.Column="1" Content="Cancel" Click="PresetCancelButton_Click" />
                        </Grid>
                        <Grid Height="4" Margin="0,0,0,10">
                            <Border CornerRadius="2" Background="{StaticResource ReSound.Surface.Hover}" />
                            <Border x:Name="PresetRunBar" Width="4"
                                    HorizontalAlignment="Left"
                                    CornerRadius="2"
                                    Background="{StaticResource ReSound.Accent.Gradient}" />
                        </Grid>
                        <ItemsControl x:Name="PresetRunSteps" MaxHeight="220">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Probing progress -->
            <Grid x:Name="ProbingRow" Margin="0,0,0,18" Visibility="Collapsed">
                <Border CornerRadius="10"
                        Padding="16,12"
                        Background="{StaticResource ReSound.Surface.Base}"
                        BorderThickness="1"
                        BorderBrush="{StaticResource ReSound.Surface.Divider}">
                    <StackPanel>
                        <TextBlock x:Name="ProbingText" Style="{StaticResource ReSound.Text.Body}" Text="Scanning system state…" Margin="0,0,0,6" />
                        <Grid Height="4">
                            <Border CornerRadius="2" Background="{StaticResource ReSound.Surface.Hover}" />
                            <Border x:Name="ProbingBar" Width="8"
                                    HorizontalAlignment="Left"
                                    CornerRadius="2"
                                    Background="{StaticResource ReSound.Accent.Gradient}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Headline stat row -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ReSound.Card.Stat}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ReSound.Text.StatLabel}" Text="TOTAL TWEAKS" />
                        <TextBlock x:Name="TotalTweaksText" Style="{StaticResource ReSound.Text.StatNumber}" Text="0" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ReSound.Card.Stat}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ReSound.Text.StatLabel}" Text="APPLIED" />
                        <TextBlock x:Name="AppliedTweaksText" Style="{StaticResource ReSound.Text.StatNumber}" Text="0" Margin="0,6,0,0"
                                   Foreground="{StaticResource ReSound.Accent.Light}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource ReSound.Card.Stat}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ReSound.Text.StatLabel}" Text="PARTIAL / UNAVAILABLE" />
                        <TextBlock x:Name="PartialTweaksText" Style="{StaticResource ReSound.Text.StatNumber}" Text="0" Margin="0,6,0,0"
                                   Foreground="{StaticResource ReSound.Status.Warning}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource ReSound.Card.Stat}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ReSound.Text.StatLabel}" Text="HIGH-RISK APPLIED" />
                        <TextBlock x:Name="HighRiskAppliedText" Style="{StaticResource ReSound.Text.StatNumber}" Text="0" Margin="0,6,0,0"
                                   Foreground="{StaticResource ReSound.Status.Danger}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Risk breakdown -->
            <Border Style="{StaticResource ReSound.Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Style="{StaticResource ReSound.Text.Title}" FontSize="16" Text="Coverage by risk" Margin="0,0,0,14" />
                    <ItemsControl x:Name="RiskBreakdownList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Category breakdown -->
            <Border Style="{StaticResource ReSound.Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Style="{StaticResource ReSound.Text.Title}" FontSize="16" Text="Coverage by category" Margin="0,0,0,14" />
                    <ItemsControl x:Name="CategoryBreakdownList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
