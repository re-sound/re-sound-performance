<Page x:Class="re_sound_performance.Views.Pages.PrivacyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:controls="clr-namespace:re_sound_performance.Controls"
      Title="Privacy">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,20">
        <StackPanel MaxWidth="1040" HorizontalAlignment="Left">
            <TextBlock Text="Privacy" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Telemetry, Copilot/Recall, advertising ID, location and scheduled tasks that upload diagnostic data." Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="14" Margin="0,0,0,24" />

            <ItemsControl x:Name="TweaksList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
