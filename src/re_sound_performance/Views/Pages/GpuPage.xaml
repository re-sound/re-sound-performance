<Page x:Class="re_sound_performance.Views.Pages.GpuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:controls="clr-namespace:re_sound_performance.Controls"
      Title="GPU">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,20">
        <StackPanel MaxWidth="1040" HorizontalAlignment="Left">
            <TextBlock Text="GPU" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Driver-level cache sizing and display pipeline toggles. NVIDIA Profile Inspector and AMD Adrenalin integration are on the roadmap." Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="14" Margin="0,0,0,24" />

            <ItemsControl x:Name="TweaksList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
