<Page x:Class="re_sound_performance.Views.Pages.ApexPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Background="{StaticResource ReSound.Surface.AppBackground}"
      Title="Apex Legends">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="44,32,44,40">
        <StackPanel MaxWidth="1100" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource ReSound.Text.Display}" Text="Apex Legends" Margin="0,0,0,6" />
            <TextBlock Style="{StaticResource ReSound.Text.Subtitle}" Text="Launch options, videoconfig, autoexec, EAC compatibility." Margin="0,0,0,24" />
            <Border Style="{StaticResource ReSound.Card}">
                <TextBlock Style="{StaticResource ReSound.Text.Body}" Text="Implementation pending." />
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
