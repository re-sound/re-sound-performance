<Page x:Class="re_sound_performance.Views.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="History">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,20">
        <StackPanel MaxWidth="1000" HorizontalAlignment="Left">
            <TextBlock Text="History" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Applied tweaks, restore points, rollback" FontSize="14" Opacity="0.7" Margin="0,0,0,24" />
            <TextBlock Text="Implementation pending" Opacity="0.5" />
        </StackPanel>
    </ScrollViewer>
</Page>
