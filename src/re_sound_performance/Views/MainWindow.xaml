<Window x:Class="re_sound_performance.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:views="clr-namespace:re_sound_performance.Views"
        Title="re_sound Performance"
        Height="780"
        Width="1280"
        MinHeight="600"
        MinWidth="1000"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.ExtendViewIntoTitleBar="True"
        ui:TitleBar.Background="Transparent">

    <ui:NavigationView x:Name="RootNav"
                       PaneDisplayMode="Left"
                       IsSettingsVisible="True"
                       IsBackButtonVisible="Collapsed"
                       SelectionChanged="RootNav_SelectionChanged">

        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="Home" Tag="home">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Home" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem Content="System tweaks" Tag="system">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Setting" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem Content="GPU" Tag="gpu">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Video" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem Content="Debloat" Tag="debloat">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Delete" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem Content="Privacy" Tag="privacy">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Permissions" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem Content="Per-game" Tag="games">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Target" />
                </ui:NavigationViewItem.Icon>
                <ui:NavigationViewItem.MenuItems>
                    <ui:NavigationViewItem Content="Counter-Strike 2" Tag="game_cs2" />
                    <ui:NavigationViewItem Content="Valorant" Tag="game_valorant" />
                    <ui:NavigationViewItem Content="Apex Legends" Tag="game_apex" />
                </ui:NavigationViewItem.MenuItems>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem Content="Benchmark" Tag="benchmark">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Clock" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem Content="History" Tag="history">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Library" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" />
    </ui:NavigationView>

</Window>
