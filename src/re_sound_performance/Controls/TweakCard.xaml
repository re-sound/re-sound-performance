<UserControl x:Class="re_sound_performance.Controls.TweakCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="900">

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="8"
            Padding="16"
            Margin="0,0,0,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock x:Name="NameText"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <Border x:Name="RiskBadge"
                            CornerRadius="10"
                            Padding="8,2"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SystemControlHighlightAccentBrush}">
                        <TextBlock x:Name="RiskText"
                                   Text="SAFE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                    </Border>

                    <Border x:Name="EvidenceBadge"
                            CornerRadius="10"
                            Padding="8,2"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                        <TextBlock x:Name="EvidenceText"
                                   Text="Confirmed"
                                   FontSize="10"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>

                <TextBlock x:Name="ShortDescriptionText"
                           FontSize="13"
                           Opacity="0.75"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Button Grid.Column="1"
                    x:Name="HelpButton"
                    Width="28"
                    Height="28"
                    Margin="12,0,8,0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1"
                    ToolTipService.InitialShowDelay="200"
                    ToolTipService.ShowDuration="20000">
                <Button.Content>
                    <TextBlock Text="?" FontSize="14" FontWeight="SemiBold" />
                </Button.Content>
                <Button.ToolTip>
                    <ToolTip Placement="Left" MaxWidth="360">
                        <StackPanel>
                            <TextBlock x:Name="TooltipTitle" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock x:Name="TooltipDetailed" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <TextBlock FontWeight="SemiBold" Text="Modifies" />
                            <TextBlock x:Name="TooltipModifies" TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,6" />
                            <TextBlock FontWeight="SemiBold" Text="Expected impact" />
                            <TextBlock x:Name="TooltipImpact" TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,6" />
                            <TextBlock FontWeight="SemiBold" Text="Risk" />
                            <TextBlock x:Name="TooltipRisk" Margin="0,0,0,6" />
                            <TextBlock FontWeight="SemiBold" Text="Sources" />
                            <ItemsControl x:Name="TooltipSources" />
                        </StackPanel>
                    </ToolTip>
                </Button.ToolTip>
            </Button>

            <ui:ToggleSwitch Grid.Column="2"
                             x:Name="ApplyToggle"
                             VerticalAlignment="Center"
                             OnContent="On"
                             OffContent="Off"
                             Toggled="ApplyToggle_Toggled" />
        </Grid>
    </Border>
</UserControl>
