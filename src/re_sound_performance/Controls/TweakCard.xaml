<UserControl x:Class="re_sound_performance.Controls.TweakCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="900">

    <Border x:Name="OuterBorder"
            CornerRadius="12"
            Background="{StaticResource ReSound.Surface.Card}"
            BorderThickness="1"
            BorderBrush="{StaticResource ReSound.Surface.Divider}"
            Margin="0,0,0,12"
            SnapsToDevicePixels="True">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#00000000" BlurRadius="0" ShadowDepth="0" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource ReSound.Surface.CardHover}" />
                        <Setter Property="BorderBrush" Value="{StaticResource ReSound.Accent.Primary}" />
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#7C3AED" BlurRadius="18" ShadowDepth="0" Opacity="0.55" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Category accent stripe with gradient -->
            <Border Grid.Column="0"
                    x:Name="AccentStripe"
                    CornerRadius="12,0,0,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop x:Name="AccentStop1" Color="#8B5CF6" Offset="0" />
                        <GradientStop x:Name="AccentStop2" Color="#5B21B6" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="20,16,12,16">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock x:Name="NameText"
                               FontFamily="{StaticResource ReSound.Font.Primary}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ReSound.Text.Primary}"
                               VerticalAlignment="Center" />

                    <Border x:Name="RiskBadge"
                            CornerRadius="10"
                            Padding="10,3"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="RiskText"
                                   Text="SAFE"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextOptions.TextFormattingMode="Display" />
                    </Border>

                    <Border x:Name="EvidenceBadge"
                            CornerRadius="10"
                            Padding="10,3"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            Background="{StaticResource ReSound.Surface.Hover}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource ReSound.Surface.Divider}">
                        <TextBlock x:Name="EvidenceText"
                                   Text="Confirmed"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ReSound.Text.Secondary}" />
                    </Border>
                </StackPanel>

                <TextBlock x:Name="ShortDescriptionText"
                           FontFamily="{StaticResource ReSound.Font.Primary}"
                           FontSize="13"
                           Foreground="{StaticResource ReSound.Text.Secondary}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Status pill -->
            <Border Grid.Column="2"
                    x:Name="StatusPill"
                    CornerRadius="10"
                    Padding="12,5"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    ToolTipService.InitialShowDelay="200"
                    ToolTipService.ShowDuration="12000">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusIcon"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock x:Name="StatusText"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Help button -->
            <Button Grid.Column="3"
                    x:Name="HelpButton"
                    Width="30"
                    Height="30"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    Foreground="{StaticResource ReSound.Text.Secondary}"
                    BorderBrush="{StaticResource ReSound.Surface.Divider}"
                    BorderThickness="1"
                    ToolTipService.InitialShowDelay="200"
                    ToolTipService.ShowDuration="20000">
                <Button.Content>
                    <TextBlock Text="?" FontSize="14" FontWeight="Bold" />
                </Button.Content>
                <Button.ToolTip>
                    <ToolTip Placement="Left" MaxWidth="380">
                        <StackPanel>
                            <TextBlock x:Name="TooltipTitle" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock x:Name="TooltipDetailed" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <TextBlock FontWeight="SemiBold" Text="Modifies" />
                            <TextBlock x:Name="TooltipModifies" TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,6" />
                            <TextBlock FontWeight="SemiBold" Text="Expected impact" />
                            <TextBlock x:Name="TooltipImpact" TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,6" />
                            <TextBlock FontWeight="SemiBold" Text="Risk" />
                            <TextBlock x:Name="TooltipRisk" Margin="0,0,0,6" />
                            <TextBlock FontWeight="SemiBold" Text="Sources" />
                            <ItemsControl x:Name="TooltipSources" />
                        </StackPanel>
                    </ToolTip>
                </Button.ToolTip>
            </Button>

            <!-- Toggle -->
            <ui:ToggleSwitch Grid.Column="4"
                             x:Name="ApplyToggle"
                             Margin="0,0,18,0"
                             VerticalAlignment="Center"
                             OnContent="On"
                             OffContent="Off"
                             Toggled="ApplyToggle_Toggled" />
        </Grid>
    </Border>
</UserControl>
